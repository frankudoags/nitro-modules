{
  "$schema": "https://nitro.margelo.com/nitro.schema.json",
  "cxxNamespace": [
    "nitrobattery"
  ],
  "ios": {
    "iosModuleName": "NitroBattery"
  },
  "android": {
    "androidNamespace": [
      "nitrobattery"
    ],
    "androidCxxLibName": "NitroBattery"
  },
  "autolinking": {
    "Battery": {
      "ios": {
        "language": "swift",
        "implementationClassName": "HybridBattery"
      },
      "android": {
        "language": "kotlin",
        "implementationClassName": "HybridBattery"
      }
    }
  },
  "ignorePaths": [
    "**/node_modules"
  ]
}
