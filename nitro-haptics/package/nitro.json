{
  "$schema": "https://nitro.margelo.com/nitro.schema.json",
  "cxxNamespace": ["nitrohaptics"],
  "ios": {
    "iosModuleName": "NitroHaptics"
  },
  "android": {
    "androidNamespace": ["nitrohaptics"],
    "androidCxxLibName": "NitroHaptics"
  },
  "autolinking": {
    "Haptics": {
      "ios": {
        "language": "swift",
        "implementationClassName": "HybridHaptics"
      },
      "android": {
        "language": "kotlin",
        "implementationClassName": "HybridHaptics"
      }
    }
  },
  "ignorePaths": ["**/node_modules"]
}
